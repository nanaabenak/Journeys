  m_Script: {fileID: 11500000, guid: 7d7e60d92295c242c8a9274787b694d3, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::CountryContextManager
  fadePanel: {fileID: 412874857}
  slideImages:
  - {fileID: -6563577315586519089, guid: 4a3424be038490c469fb84c48689d36e, type: 3}
  - {fileID: -8189709279097190757, guid: 72c3fd32c85f6df148f0833fdea6f901, type: 3}
  - {fileID: 5484020137854153061, guid: f3cdf0b14a409828387cb29605d532b8, type: 3}
  slideImage: {fileID: 1037498025}
  slideFadeDuration: 0.4
  typewriter: {fileID: 1601903512}
  slideTexts:
  - "\"Welcome, traveller. Smart choice, starting here.\"  \"I'm Kwame. And this
    \u2014 is Ghana.\"  \"West Africa's golden child. Famous for its warmth, its
    people, its rhythm, and its rich, rich earth.\"  \"A place full of life. Full
    of colour. Full of possibility.\"  \"But like every great nation \u2014 it has
    its battles.\"\"Come and see for yourself.\""
  - "\"Not every child in this country gets the same start in life. Some doors are
    harder to open than others.\"  \"And somewhere out there, the land is hurting.
    Quietly. Slowly. But it is.\"  \"I won't say more than that \u2014 not yet.\""
  - uuhcdhwyguwhuh
  nextButton: {fileID: 1538713207}
  nextButtonText: {fileID: 1954998208}
  storyPickerPanel: {fileID: 1538713206}
  educationButton: {fileID: 889537634}
  galenseyButton: {fileID: 267694521}
  delegateImage: {fileID: 1482676176}
